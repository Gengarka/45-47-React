{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "~/*": ["./app/*"]
        }
    },
    "include": ["app/**/*", "vite.config.ts", "routes.ts"],
    "exclude": ["node_modules", "build"]
}